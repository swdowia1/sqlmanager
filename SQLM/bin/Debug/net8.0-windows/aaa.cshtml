@using ExpertSender.Cdp.Common.Enums
@using Resources = Resources.Resources
@using ClientResources = Client.Resources.Resources;
@using MessageResources = Common.Resources.EmailMessages;
@using ExpertSender.Cdp.Web.Client.Features.EmailMessages.Models

@model IndexViewModel

@{
    var isSelectContentView = Model.IsSelectContentViewModel;
    // for select content view we need to show only newsletters with the same editor type as a current newsletter
    EditorType? limitToEditorType = isSelectContentView ? Model.EditorType : null;
}

@(Html.Kendo().Grid<NewsletterListItem>()
    .Name("ecdp-newsletters-grid-all")
    .EsPlaceholders(!isSelectContentView, null, "createNewsletterClick", Resources.CreateEmail)
    .Columns(columns =>
    {
        columns.BoundEnumBadge(p => p.Status).MinWidth(142)
            .HeaderHtmlAttributes(new { @class = "filterHighlight" })
            .Title(Common.Resources.Common.Status);
        columns.Bound(p => p.Id).MinWidth(60)
            .Title(Common.Resources.Common.Id)
            .ClientTemplate("<span class='# if (ApplyLiveUpdate) { # ecdp-liveUpdate-id # } #'>#= Id #</span>");
        columns.Bound(p => p.Subject).MinWidth(250)
            .ClientHeaderTemplate(Resources.NameSubject + "<i class='icon-attachment header-paperclip'></i>")
            .ClientTemplate("#= subjectTemplate(data) #");
        columns.Bound(p => p.Revenue).MinWidth(85)
            .Title(Common.Resources.Common.Revenue)
            .ClientTemplate("<div class='ecdp-grid-primary-val ecdp-liveUpdate-revenue'>#= kendo.toString(Revenue, 'N2') #</div>");
        columns.BoundEnum(b => b.EditorType).Title(Common.Resources.Common.EditorType).Width(180);
        columns.Bound(p => p.SendDate).MinWidth(140)
            .Title(Resources.SendDate)
            .ClientTemplate("#= SendDateLabel #");
        if (!isSelectContentView)
        {
            columns.Bound(p => p.Sent).MinWidth(100)
                .Title(Client.Resources.Resources.Sent)
                .ClientTemplate("<div class='ecdp-grid-primary-val ecdp-liveUpdate-sent'>#= Sent #</div>");
            columns.Bound(p => p.Opens).MinWidth(70)
                .Title(ClientResources.Opens)
                .ClientTemplate("<div class='ecdp-grid-primary-val ecdp-liveUpdate-opensRatio'>#= OpensRatio #%</div>" +
                                "<div class='ecdp-grid-secondary-val ecdp-liveUpdate-opens'>#= Opens #</div>");
            columns.Bound(p => p.Clicks).MinWidth(70)
                .Title(ClientResources.Clicks)
                .ClientTemplate("<div class='ecdp-grid-primary-val ecdp-liveUpdate-clicksRatio'>#= ClicksRatio #%</div>" +
                                "<div class='ecdp-grid-secondary-val ecdp-liveUpdate-clicks'>#= Clicks #</div>");
            columns.Bound(p => p.CTOR).MinWidth(70)
                .Title(ClientResources.Ctor)
                .ClientTemplate("<div class='ecdp-grid-primary-val ecdp-liveUpdate-ctor'>#= CTOR #%</div>");
            columns.Bound(p => p.Bounces).MinWidth(70)
                .Title(ClientResources.Bounces)
                .ClientTemplate("<div class='ecdp-grid-primary-val ecdp-liveUpdate-bouncesRatio'>#= BouncesRatio #%</div>" +
                                "<div class='ecdp-grid-secondary-val ecdp-liveUpdate-bounces'>#= Bounces #</div>");
            columns.Bound(p => p.Unsubscribed).MinWidth(70)
                .Title(ClientResources.Unsubscribed)
                .ClientTemplate("<div class='ecdp-grid-primary-val ecdp-liveUpdate-unsubscribedRatio'>#= UnsubscribedRatio #%</div>" +
                                "<div class='ecdp-grid-secondary-val ecdp-liveUpdate-unsubscribed'>#= Unsubscribed #</div>");
        }
        columns.Command(command =>
        {
            if (isSelectContentView)
            {
                command.ShowAjaxWindow("previewEmail")
                    .IconClass("icon-eye-view")
                    .Tooltip(CommonResources.PreviewAndDetails)
                    .Url(Url.Action("Preview", "EmailMessages"), "Id")
                    .Window("ecdp-preview-email-window")
                    .Visible("isNotAbTest");
                command.Custom("reuseContent")
                    .Text(" ")
                    .IconClass("icon-circle-plus-add")
                    .Click("reuseContent")
                    .Visible("isNotAbTest")
                    .HtmlAttributes(new
                    {
                        data_tooltip = CommonResources.Select,
                        @class = "ecdp-secondary-button ecdp-grid-action green"
                    });
            }
            else
            {
                command.ShowAjaxWindow("previewEmail")
                    .IconClass("icon-eye-view")
                    .Tooltip(CommonResources.PreviewAndDetails)
                    .Url(Url.Action("Preview", "EmailMessages"), "Id")
                    .Window("ecdp-preview-email-window");
                command.Redirect("showReports", "ecdp-newsletters-grid-all")
                    .Url(Url.Action("Index", "EmailMessageReports"), "Id")
                    .IconClass("icon-business-chart")
                    .Tooltip(Common.Resources.Common.Reports)
                    .Visible("checkStatusForReports");
                command.DoAjaxRequest("resumeMessage")
                    .IconClass("icon-play")
                    .ButtonClass("green")
                    .Tooltip(Resources.Resume)
                    .Url(Url.Action("Resume", "EmailMessages"), "Id")
                    .Confirm(MessageResources.WarningResumeMessage, "Id")
                    .ButtonOk(CommonResources.Yes)
                    .ButtonCancel(CommonResources.No)
                    .Refresh(true)
                    .Visible("checkStatusForResume");
                command.DoAjaxRequest("pauseMessage")
                    .IconClass("icon-pause")
                    .ButtonClass("orange")
                    .Tooltip(Resources.Pause)
                    .Url(Url.Action("Pause", "EmailMessages"), "Id")
                    .Confirm(MessageResources.WarningPauseMessage, "Id")
                    .ButtonOk(CommonResources.Yes)
                    .ButtonCancel(CommonResources.No)
                    .Refresh(true)
                    .Visible("checkStatusForPause");
                command.DoAjaxRequest("cancelMessageAndMoveToPaused")
                    .IconClass("icon-circle-cross-remove")
                    .ButtonClass("orange")
                    .Tooltip(Resources.CancelAndMoveToPaused)
                    .Url(Url.Action("CancelAndMoveToPaused", "EmailMessages"), "Id")
                    .Confirm(MessageResources.WarningCancelMessageAndMoveToPaused, "Id")
                    .ButtonOk(Resources.Pause)
                    .ButtonCancel(CommonResources.No)
                    .Refresh(true)
                    .Visible("checkStatusForCancelAndMoveToPaused");
                command.DoAjaxRequest("cancelMessageAndMoveToDrafts")
                    .IconClass("icon-circle-cross-remove")
                    .ButtonClass("orange")
                    .Tooltip(Resources.CancelAndMoveToDrafts)
                    .Url(Url.Action("CancelAndMoveToDrafts", "EmailMessages"), "Id")
                    .Confirm(MessageResources.WarningCancelMessageAndMoveToDrafts, "Id")
                    .ButtonOk(CommonResources.Yes)
                    .ButtonCancel(CommonResources.No)
                    .Refresh(true)
                    .Visible("checkStatusForCancelAndMoveToDrafts");
                command.Redirect("editMessage", "ecdp-newsletters-grid-all")
                    .Url(Url.Action("Index", "NewsletterWizard"), "Id")
                    .IconClass("icon-pen-edit")
                    .Tooltip(Common.Resources.Common.Edit)
                    .Visible("checkStatusForEdit");
                command.DuplicateWindow("duplicateNewsletter", nameof(NewsletterListItem.Status), nameof(NewsletterListItem.NewsletterType)).RefreshGrid();
                command.DoAjaxRequest("deleteMessage")
                    .IconClass("icon-trash-delete-bin")
                    .ButtonClass("red")
                    .Tooltip(Common.Resources.Common.Delete)
                    .Url(Url.Action("Delete", "EmailMessages"), "Id")
                    .Confirm(MessageResources.WarningDeleteMessage, "Id")
                    .ButtonOk(CommonResources.Delete)
                    .ButtonCancel(CommonResources.Cancel)
                    .IsDeleteConfirmation(true)
                    .Refresh(true)
                    .Visible("checkStatusForDelete");
                command.DoAjaxRequest("restoreMessage")
                    .IconClass("icon-rotate-refresh-loading")
                    .ButtonClass("green")
                    .Tooltip(Resources.Restore)
                    .Url(Url.Action("Restore", "EmailMessages"), "Id")
                    .Confirm(Resources.RestoreConfirmQuestion, "Id")
                    .ButtonOk(CommonResources.Yes)
                    .ButtonCancel(CommonResources.No)
                    .Refresh(true)
                    .Visible("checkStatusForRestore");
            }
        }).MinWidth(isSelectContentView ? 50 : 125);
    })
    .Pageable(pager => pager.ClientDefaultPaging())
    .Navigatable()
    .Sortable()
    .DataSource(dataSource => dataSource
        .Ajax()
        .Batch(true)
        .ServerOperation(true)
        .Read(r => r.Action("GetNewsletters", "EmailMessages", new { limitToEditorType }).Type(HttpVerbs.Get))
    ).Events(e => e
        .DataBound("newslettersGridDataBound")
        .DetailExpand("onAbTestDetailExpand")
        .DetailCollapse("onAbTestDetailCollapse"))
    .ClientDetailTemplateId("abTestDetailsTemplate")
    .ApplyFlexSearchFilters(readData: false)
    .SetUserPreferences(readData: true)
)

@await Html.PartialAsync("_AdditionalComponentScriptsForAjax")